{
  "name": "crm-mini",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "cross-env NODE_ENV=production node src/server.js",
    "build": "cross-env NODE_ENV=production yarn install && yarn prisma:generate",
    "dev": "cross-env NODE_ENV=development node --watch src/server.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prisma:generate": "prisma generate",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "http-status-codes": "^2.3.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "prisma": "^7.4.2"
  }
}
