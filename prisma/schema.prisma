generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model COMPANY {
  COMPANY_ID   Int         @id @default(autoincrement()) @map("COMPANY_ID")
  COMPANY_NAME String      @map("COMPANY_NAME")
  STATUS       ENUMSTATUS  @default(ENABLE) @map("STATUS")
  CREATED_AT   DateTime    @default(now()) @map("CREATED_AT")
  UPDATED_AT   DateTime    @updatedAt @map("UPDATED_AT")
  Divisions    DIVISIONS[]

  @@map("COMPANY")
}

model DIVISIONS {
  DIVISION_ID   Int         @id @default(autoincrement()) @map("DIVISION_ID")
  DIVISION_NAME String      @map("DIVISION_NAME")
  COMPANY_ID    Int         @map("COMPANY_ID")
  STATUS        ENUMSTATUS  @default(ENABLE) @map("STATUS")
  CREATED_AT    DateTime    @default(now()) @map("CREATED_AT")
  UPDATED_AT    DateTime    @updatedAt @map("UPDATED_AT")
  COMPANY       COMPANY     @relation(fields: [COMPANY_ID], references: [COMPANY_ID])
  ORG_UNITS     ORG_UNITS[]

  @@map("DIVISIONS")
}

model ORG_UNITS {
  ORG_UNIT_ID    Int         @id @default(autoincrement()) @map("ORG_UNIT_ID")
  UNIT_NAME      String      @map("UNIT_NAME")
  UNIT_TYPE      String?     @map("UNIT_TYPE")
  DIVISION_ID    Int?        @map("DIVISION_ID")
  PARENT_UNIT_ID Int?        @map("PARENT_UNIT_ID")
  STATUS         ENUMSTATUS  @default(ENABLE) @map("STATUS")
  CREATED_AT     DateTime    @default(now()) @map("CREATED_AT")
  UPDATED_AT     DateTime    @updatedAt @map("UPDATED_AT")
  BRANCHES       BRANCHES[]
  EMPLOYEES      EMPLOYEES[]
  DIVISION       DIVISIONS?  @relation(fields: [DIVISION_ID], references: [DIVISION_ID])

  @@map("ORG_UNITS")
}

model BRANCHES {
  BRANCH_ID   Int        @id @default(autoincrement()) @map("BRANCH_ID")
  BRANCH_NAME String     @map("BRANCH_NAME")
  LOCATION    String?    @map("LOCATION")
  STATUS      ENUMSTATUS @default(ENABLE) @map("STATUS")
  CREATED_AT  DateTime   @default(now()) @map("CREATED_AT")
  UPDATED_AT  DateTime   @updatedAt @map("UPDATED_AT")
  ORG_UNIT_ID Int?       @map("ORG_UNIT_ID")
  ORG_UNIT    ORG_UNITS? @relation(fields: [ORG_UNIT_ID], references: [ORG_UNIT_ID])

  @@map("BRANCHES")
}

model POSITIONS {
  POSITION_ID   Int        @id @default(autoincrement()) @map("POSITION_ID")
  POSITION_NAME String     @map("POSITION_NAME")
  LEVEL         String     @map("LEVEL")
  STATUS        ENUMSTATUS @default(ENABLE) @map("STATUS")
  CREATED_AT    DateTime   @default(now()) @map("CREATED_AT")
  UPDATED_AT    DateTime   @updatedAt @map("UPDATED_AT")
  NEW_COLUMN    BigInt?    @map("NEW_COLUMN")
  EMPLOYEE_ID   Int?       @map("EMPLOYEE_ID")
  EMPLOYEE      EMPLOYEES? @relation(fields: [EMPLOYEE_ID], references: [EMPLOYEE_ID])

  @@map("POSITIONS")
}

model EMPLOYEES {
  EMPLOYEE_ID   Int           @id @default(autoincrement()) @map("EMPLOYEE_ID")
  EMPLOYEE_CODE String        @map("EMPLOYEE_CODE")
  FIRST_NAME    String        @map("FIRST_NAME")
  LAST_NAME     String        @map("LAST_NAME")
  PHONE         String?       @map("PHONE")
  EMAIL         String?       @map("EMAIL")
  BIRTH_DATE    DateTime      @map("BIRTH_DATE") @db.Date
  UNIT_ID       Int?          @map("UNIT_ID")
  VT_CODE       Int?          @map("VT_CODE")
  STATUS        ENUMSTATUS    @default(ENABLE) @map("STATUS")
  CREATED_AT    DateTime      @default(now()) @map("CREATED_AT")
  UPDATED_AT    DateTime      @updatedAt @map("UPDATED_AT")
  ACCOUNTS      ACCOUNTS[]
  ORG_UNIT      ORG_UNITS?    @relation(fields: [UNIT_ID], references: [ORG_UNIT_ID])
  EMPLOYEE_VTS  EMPLOYEE_VT[]
  IPS           IPS[]
  POSITIONS     POSITIONS[]

  @@map("EMPLOYEES")
}

model ACCOUNTS {
  ACCOUNT_ID    Int             @id @default(autoincrement()) @map("ACCOUNT_ID")
  PASSWORD      String?         @map("PASSWORD")
  EMPLOYEE_ID   Int?            @map("EMPLOYEE_ID")
  IS_LOGIN      Boolean         @default(false) @map("IS_LOGIN")
  LOGIN         Int             @default(0) @map("LOGIN")
  STATUS        ENUMSTATUS      @default(ENABLE) @map("STATUS")
  CREATED_AT    DateTime        @default(now()) @map("CREATED_AT")
  UPDATED_AT    DateTime        @updatedAt @map("UPDATED_AT")
  EMPLOYEE      EMPLOYEES?      @relation(fields: [EMPLOYEE_ID], references: [EMPLOYEE_ID])
  ACCOUNT_ROLES ACCOUNT_ROLES[]

  @@map("ACCOUNTS")
}

model ACCOUNT_ROLES {
  AR_ID      Int       @id @default(autoincrement()) @map("AR_ID")
  ACCOUNT_ID Int?      @map("ACCOUNT_ID")
  ROLE_ID    Int?      @map("ROLE_ID")
  CREATED_AT DateTime  @default(now()) @map("CREATED_AT")
  UPDATED_AT DateTime  @updatedAt @map("UPDATED_AT")
  ACCOUNT    ACCOUNTS? @relation(fields: [ACCOUNT_ID], references: [ACCOUNT_ID])
  ROLE       ROLES?    @relation(fields: [ROLE_ID], references: [ROLE_ID])

  @@map("ACCOUNT_ROLES")
}

model ROLES {
  ROLE_ID       Int             @id @default(autoincrement()) @map("ROLE_ID")
  ROLE_NAME     String          @map("ROLE_NAME")
  DESCRIPTION   String?         @map("DESCRIPTION")
  CREATED_BY    Int?            @map("CREATED_BY")
  STATUS        ENUMSTATUS      @default(ENABLE) @map("STATUS")
  UPDATED_BY    DateTime        @map("UPDATED_BY")
  UPDATED_AT    DateTime        @updatedAt @map("UPDATED_AT")
  CREATED_AT    DateTime        @default(now()) @map("CREATED_AT")
  ACCOUNT_ROLES ACCOUNT_ROLES[]
  PERMISSIONS   PERMISSIONS[]

  @@map("ROLES")
}

model PERMISSIONS {
  PER_ID     Int        @id @default(autoincrement()) @map("PER_ID")
  PER_NAME   String     @map("PER_NAME")
  GRANTED_BY DateTime   @map("GRANTED_BY")
  REVOKED_AT DateTime?  @map("REVOKED_AT")
  NOTES      String?    @map("NOTES")
  ROLE_ID    Int?       @map("ROLE_ID")
  STATUS     ENUMSTATUS @default(ENABLE) @map("STATUS")
  CREATED_AT DateTime   @default(now()) @map("CREATED_AT")
  UPDATED_AT DateTime   @updatedAt @map("UPDATED_AT")
  ROLE       ROLES?     @relation(fields: [ROLE_ID], references: [ROLE_ID])

  @@map("PERMISSIONS")
}

model VLANS {
  VLAN_ID         Int        @id @default(1) @map("VLAN_ID")
  VLAN_NAME       String     @map("VLAN_NAME")
  NETWORK         String     @map("NETWORK")
  DEFAULT_GATEWAY String?    @map("DEFAULT_GATEWAY")
  SUBNET_MASK     String?    @map("SUBNET_MASK")
  IP_RANGE        String     @map("IP_RANGE")
  STATUS          ENUMSTATUS @default(ENABLE) @map("STATUS")
  CREATED_AT      DateTime   @default(now()) @map("CREATED_AT")
  UPDATED_AT      DateTime   @updatedAt @map("UPDATED_AT")
  IPS             IPS[]

  @@map("VLANS")
}

model IPS {
  IP_ID       Int            @id @default(autoincrement()) @map("IP_ID")
  HOST        String         @map("HOST")
  VLAN_ID     Int            @map("VLAN_ID")
  DEVICE_TYPE String?        @map("DEVICE_TYPE")
  EMPLOYEE_ID Int?           @map("EMPLOYEE_ID")
  STATUS      NETWORK_STATUS @default(INACTIVE) @map("STATUS")
  CREATED_AT  DateTime       @default(now()) @map("CREATED_AT")
  UPDATED_AT  DateTime       @updatedAt @map("UPDATED_AT")
  EMPLOYEE    EMPLOYEES?     @relation(fields: [EMPLOYEE_ID], references: [EMPLOYEE_ID])
  VLAN        VLANS          @relation(fields: [VLAN_ID], references: [VLAN_ID])

  @@map("IPS")
}

model EMPLOYEE_VT {
  ID        Int        @id @default(autoincrement()) @map("ID")
  VT_CODE   Int        @unique @map("VT_CODE")
  VT_EMAIL  String     @unique @map("VT_EMAIL")
  STATUS    ENUMSTATUS @default(ENABLE) @map("STATUS")
  CREATE_AT DateTime   @default(now()) @map("CREATE_AT")
  UPDATE_AT DateTime   @updatedAt @map("UPDATE_AT")
  VT_ID     Int?       @map("VT_ID")
  EMPLOYEE  EMPLOYEES? @relation(fields: [VT_ID], references: [EMPLOYEE_ID])

  @@map("EMPLOYEE_VT")
}

enum ENUMSTATUS {
  ENABLE
  DISABLED
}

enum NETWORK_STATUS {
  AVAILABLE
  ASSIGNED
  ACTIVE
  INACTIVE
  DISABLED
  CONFLICT
}
